c. Declare variables and write a function to calculate the sum of two
numbers and display the result.
Code : 
function App() {


  const maths = 85;
  const sci = 90;


  function calculate(mark1, mark2) {
    return mark1 + mark2;
  }


  return (
    <div>
      <h1>Student Marks</h1>
      <hr />
      <p>Mathematics Marks : {maths}</p>
      <p>Science Marks : {sci}</p>
      <hr />
      <h2>Total Marks : {calculate(maths, sci)}</h2>
      <h3>Rabiya  (T034)</h3>
    </div>
  );
}
  export default App
